<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Plants.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Plants"
    xmlns:views="clr-namespace:Plants.Views"
    Title="Plants"
    FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Сад"
            Route="home"
            ContentTemplate="{DataTemplate local:MainPage}" />
        <ShellContent
            Title="Растения"
            Route="plants"
            ContentTemplate="{DataTemplate views:PlantsPage}" />
        <ShellContent
            Title="Проблемы"
            Route="library"
            ContentTemplate="{DataTemplate views:PestLibraryPage}" />
        <ShellContent
            Title="Задачи"
            Route="tasks"
            ContentTemplate="{DataTemplate views:TasksPage}" />
        <ShellContent
            Title="Еще"
            Route="settings"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>
</Shell>
