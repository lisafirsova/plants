<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Plants.Views.PlantsPage"
             x:Name="PlantsPageRoot"
             Title="Растения">
    <Grid RowDefinitions="Auto,*" Padding="20,18" RowSpacing="16">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="4">
                <Label Text="Растения" FontSize="28" FontFamily="OpenSansSemibold" />
                <Label Text="Коллекция и быстрые карточки ухода" TextColor="{StaticResource TextMuted}" />
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="+"
                    FontSize="22"
                    WidthRequest="48"
                    Command="{Binding NewPlantCommand}" />
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Plants}">
            <CollectionView.EmptyView>
                <Label Text="Список растений пуст."
                       TextColor="{StaticResource TextMuted}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.Header>
                <Border Padding="14" Margin="0,0,0,12" IsVisible="{Binding IsEditing}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding EditorTitle}" FontSize="18" FontFamily="OpenSansSemibold" />
                        <Entry Placeholder="Название" Text="{Binding Name}" />
                        <Entry Placeholder="Латинское название" Text="{Binding LatinName}" />
                        <Entry Placeholder="Тип" Text="{Binding Type}" />
                        <Entry Placeholder="Место" Text="{Binding Location}" />
                        <Entry Placeholder="Подсказка по поливу" Text="{Binding WateringHint}" />
                        <Entry Placeholder="Статус здоровья" Text="{Binding HealthStatus}" />
                        <Editor Placeholder="Заметки" Text="{Binding Notes}" AutoSize="TextChanges" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Text="Сохранить" Command="{Binding SavePlantCommand}" />
                            <Button Grid.Column="1"
                                    Text="Отмена"
                                    BackgroundColor="{StaticResource SurfaceAlt}"
                                    TextColor="{StaticResource TextPrimary}"
                                    Command="{Binding CancelEditCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="14" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="12,*,Auto"
                              RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="6">
                            <BoxView Grid.RowSpan="3"
                                     Color="{Binding AccentColor}"
                                     WidthRequest="12"
                                     CornerRadius="6" />
                            <Label Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="20"
                                   FontFamily="OpenSansSemibold" />
                            <Label Grid.Column="1"
                                   Grid.Row="1"
                                   Text="{Binding LatinName}"
                                   TextColor="{StaticResource TextMuted}" />
                            <Label Grid.Column="1"
                                   Grid.Row="2"
                                   Text="{Binding Location}"
                                   TextColor="{StaticResource TextMuted}" />
                            <VerticalStackLayout Grid.Column="2"
                                                 Grid.RowSpan="3"
                                                 Spacing="8"
                                                 WidthRequest="92">
                                <Button Text="Открыть"
                                        FontSize="12"
                                        Padding="8,6"
                                        Command="{Binding BindingContext.OpenPlantCommand, Source={x:Reference PlantsPageRoot}}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Править"
                                        FontSize="12"
                                        Padding="8,6"
                                        BackgroundColor="{StaticResource SurfaceAlt}"
                                        TextColor="{StaticResource TextPrimary}"
                                        Command="{Binding BindingContext.EditPlantCommand, Source={x:Reference PlantsPageRoot}}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Удалить"
                                        FontSize="12"
                                        Padding="8,6"
                                        BackgroundColor="{StaticResource Danger}"
                                        Command="{Binding BindingContext.DeletePlantCommand, Source={x:Reference PlantsPageRoot}}"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
