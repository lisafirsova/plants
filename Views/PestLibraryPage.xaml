<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Plants.Views.PestLibraryPage"
             x:Name="LibraryPageRoot"
             Title="Справочник">
    <ScrollView>
        <VerticalStackLayout Padding="20,18" Spacing="18">
            <VerticalStackLayout Spacing="4">
                <Label Text="Справочник проблем" FontSize="28" FontFamily="OpenSansSemibold" />
                <Label Text="Мок-карточки вредителей и болезней комнатных растений."
                       TextColor="{StaticResource TextMuted}" />
            </VerticalStackLayout>

            <Label Text="Вредители" FontSize="20" FontFamily="OpenSansSemibold" />
            <VerticalStackLayout Spacing="12" BindableLayout.ItemsSource="{Binding Pests}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14">
                            <Grid ColumnDefinitions="10,*,Auto" ColumnSpacing="12">
                                <BoxView Color="{Binding AccentColor}" WidthRequest="10" CornerRadius="5" />
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding Name}" FontSize="18" FontFamily="OpenSansSemibold" />
                                    <Label Text="{Binding Severity}" TextColor="{StaticResource TextMuted}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="2"
                                        Text="Открыть"
                                        Command="{Binding BindingContext.OpenIssueCommand, Source={x:Reference LibraryPageRoot}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Label Text="Болезни" FontSize="20" FontFamily="OpenSansSemibold" />
            <VerticalStackLayout Spacing="12" BindableLayout.ItemsSource="{Binding Diseases}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14">
                            <Grid ColumnDefinitions="10,*,Auto" ColumnSpacing="12">
                                <BoxView Color="{Binding AccentColor}" WidthRequest="10" CornerRadius="5" />
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding Name}" FontSize="18" FontFamily="OpenSansSemibold" />
                                    <Label Text="{Binding Severity}" TextColor="{StaticResource TextMuted}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="2"
                                        Text="Открыть"
                                        Command="{Binding BindingContext.OpenIssueCommand, Source={x:Reference LibraryPageRoot}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
